{
  "name": "@mrazakos/vc-ecdsa-crypto",
  "version": "3.1.0",
  "description": "Fast ECDSA cryptographic utilities for Verifiable Credentials - 100-1000x faster than RSA on mobile devices. Smart contract ready with Ethereum address-based public keys.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "npm run build && jest",
    "benchmark:pi": "npm run build && node scripts/pi-benchmark.js",
    "clean": "rimraf dist",
    "research:comparison": "powershell -ExecutionPolicy Bypass -File research/experiments/comparison-tests/run-comparison.ps1",
    "research:docker:mobile": "powershell -ExecutionPolicy Bypass -File research/experiments/docker-benchmarks/mobile/run-mobile-benchmark.ps1",
    "research:docker:iot": "powershell -ExecutionPolicy Bypass -File research/experiments/docker-benchmarks/iot/run-iot-benchmark.ps1",
    "research:anova": "powershell -ExecutionPolicy Bypass -File research/analysis/anova/run-anova.ps1",
    "research:all": "npm run research:comparison && npm run research:docker:mobile && npm run research:docker:iot && npm run research:anova"
  },
  "keywords": [
    "ecdsa",
    "crypto",
    "verifiable-credentials",
    "ethereum",
    "secp256k1",
    "signing",
    "verification",
    "fast-crypto",
    "mobile-crypto"
  ],
  "author": "Mrazakos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mrazakos/vc-ecdsa-crypto.git"
  },
  "bugs": {
    "url": "https://github.com/Mrazakos/vc-ecdsa-crypto/issues"
  },
  "homepage": "https://github.com/Mrazakos/vc-ecdsa-crypto#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@noble/post-quantum": "^0.2.1",
    "ethers": "^6.13.0",
    "node-forge": "^1.3.3",
    "node-rsa": "^1.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/node-forge": "^1.3.14",
    "@types/node-rsa": "^1.1.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}